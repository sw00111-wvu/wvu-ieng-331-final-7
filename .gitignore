from __future__ import annotations

from dataclasses import dataclass
from pathlib import Path
from typing import Literal

import polars as pl
from statsforecast import StatsForecast
from statsforecast.models import AutoARIMA, AutoETS, SeasonalNaive

MetricName = Literal["monthly_revenue", "order_volume", "delivery_days"]

DATASETS = {
    "orders": "https://raw.githubusercontent.com/olist/work-at-olist-data/master/datasets/olist_orders_dataset.csv",
    "order_items": "https://raw.githubusercontent.com/olist/work-at-olist-data/master/datasets/olist_order_items_dataset.csv",
    "products": "https://raw.githubusercontent.com/olist/work-at-olist-data/master/datasets/olist_products_dataset.csv",
    "translation": "https://raw.githubusercontent.com/olist/work-at-olist-data/master/datasets/product_category_name_translation.csv",
    "sellers": "https://raw.githubusercontent.com/olist/work-at-olist-data/master/datasets/olist_sellers_dataset.csv",
}

MODEL_FACTORIES = {
    "AutoARIMA": lambda: AutoARIMA(season_length=12),
    "SeasonalNaive": lambda: SeasonalNaive(season_length=12),
    "AutoETS": lambda: AutoETS(season_length=12),
}


@dataclass
class ForecastResult:
    ok: bool
    message: str
    history: pl.DataFrame
    forecast: pl.DataFrame


def _load_csv(cache_dir: Path, name: str, url: str) -> pl.DataFrame:
    cache_dir.mkdir(parents=True, exist_ok=True)
    cache_path = cache_dir / f"{name}.csv"
    if not cache_path.exists():
        df = pl.read_csv(url)
        df.write_csv(cache_path)
    return pl.read_csv(cache_path)


def load_olist_frames(cache_dir: str | Path = "data/cache") -> dict[str, pl.DataFrame]:
    """Load the Olist tables needed for this app with local caching."""
    cache_path = Path(cache_dir)
    return {
        name: _load_csv(cache_path, name, url)
        for name, url in DATASETS.items()
    }


def build_monthly_series(
    metric: MetricName,
    category: str = "All",
    seller_state: str = "All",
    cache_dir: str | Path = "data/cache",
) -> tuple[pl.DataFrame, str]:
    """Build a monthly series for the selected metric and filters."""
    tables = load_olist_frames(cache_dir=cache_dir)

    orders = tables["orders"].with_columns(
        pl.col("order_purchase_timestamp").str.to_datetime(strict=False),
        pl.col("order_delivered_customer_date").str.to_datetime(strict=False),
    )

    order_items = tables["order_items"]
    products = tables["products"]
    translation = tables["translation"]
    sellers = tables["sellers"]

    product_lookup = products.join(
        translation,
        on="product_category_name",
        how="left",
    ).with_columns(
        pl.col("product_category_name_english").fill_null("unknown")
    )

    base = (
        order_items.join(
            orders.select(
                [
                    "order_id",
                    "order_purchase_timestamp",
                    "order_delivered_customer_date",
                    "order_status",
                ]
            ),
            on="order_id",
            how="inner",
        )
        .join(
            product_lookup.select(["product_id", "product_category_name_english"]),
            on="product_id",
            how="left",
        )
        .join(sellers.select(["seller_id", "seller_state"]), on="seller_id", how="left")
        .filter(pl.col("order_status").is_in(["delivered", "shipped", "invoiced"]))
    )

    if category != "All":
        base = base.filter(pl.col("product_category_name_english") == category)

    if seller_state != "All":
        base = base.filter(pl.col("seller_state") == seller_state)

    if base.is_empty():
        return pl.DataFrame({"ds": [], "y": []}), "No data available for selected filters."

    with_month = base.with_columns(
        pl.col("order_purchase_timestamp").dt.truncate("1mo").alias("ds"),
        (pl.col("order_delivered_customer_date") - pl.col("order_purchase_timestamp"))
        .dt.total_days()
        .alias("delivery_days"),
    )

    if metric == "monthly_revenue":
        monthly = with_month.group_by("ds").agg(
            (pl.col("price") + pl.col("freight_value")).sum().alias("y")
        )
    elif metric == "order_volume":
        monthly = with_month.group_by("ds").agg(pl.col("order_id").n_unique().alias("y"))
    else:
        monthly = with_month.group_by("ds").agg(
            pl.col("delivery_days").drop_nulls().mean().alias("y")
        )

    monthly = (
        monthly.sort("ds")
        .filter(pl.col("y").is_not_null())
        .with_columns(pl.col("y").cast(pl.Float64))
    )

    if monthly.is_empty():
        return monthly, "No valid data points found after aggregation."

    return monthly, ""


def run_forecast(
    metric: MetricName,
    model_name: str,
    horizon: int,
    category: str = "All",
    seller_state: str = "All",
    min_points: int = 18,
    cache_dir: str | Path = "data/cache",
) -> ForecastResult:
    """Forecast the selected metric with statsforecast and return history + projection."""
    series, msg = build_monthly_series(
        metric=metric,
        category=category,
        seller_state=seller_state,
        cache_dir=cache_dir,
    )

    if series.is_empty():
        return ForecastResult(False, msg, series, pl.DataFrame())

    n = series.height
    if n < min_points:
        return ForecastResult(
            False,
            f"Need at least {min_points} monthly observations for forecasting. Found {n}.",
            series,
            pl.DataFrame(),
        )

    if model_name not in MODEL_FACTORIES:
        return ForecastResult(
            False,
            f"Unknown model '{model_name}'. Choose one of: {', '.join(MODEL_FACTORIES)}.",
            series,
            pl.DataFrame(),
        )

    sf_input = series.select(
        pl.lit("selected_series").alias("unique_id"),
        pl.col("ds"),
        pl.col("y"),
    )

    model = MODEL_FACTORIES[model_name]()
    forecaster = StatsForecast(models=[model], freq="MS", n_jobs=1)
    fcst = forecaster.forecast(df=sf_input.to_pandas(), h=horizon, level=[80, 95])

    forecast_df = (
        pl.from_pandas(fcst)
        .rename(
            {
                model_name: "yhat",
                f"{model_name}-lo-80": "lo80",
                f"{model_name}-hi-80": "hi80",
                f"{model_name}-lo-95": "lo95",
                f"{model_name}-hi-95": "hi95",
            }
        )
        .select(["ds", "yhat", "lo80", "hi80", "lo95", "hi95"])
        .with_columns(pl.col("ds").cast(pl.Datetime))
    )

    return ForecastResult(True, "", series, forecast_df)


def available_filters(cache_dir: str | Path = "data/cache") -> tuple[list[str], list[str]]:
    """Return sorted category and seller-state options for UI controls."""
    tables = load_olist_frames(cache_dir=cache_dir)
    products = tables["products"]
    translation = tables["translation"]
    sellers = tables["sellers"]

    categories = (
        products.join(translation, on="product_category_name", how="left")
        .select(pl.col("product_category_name_english").fill_null("unknown"))
        .unique()
        .sort("product_category_name_english")
        .to_series()
        .to_list()
    )
    states = sellers.select("seller_state").drop_nulls().unique().sort("seller_state").to_series().to_list()

    return ["All", *categories], ["All", *states]
@app.cell
def _(marimo, result):
    if not result.ok:
        return

    latest_actual = result.history.sort("ds").tail(1).to_dicts()[0]
    first_fcst = result.forecast.sort("ds").head(1).to_dicts()[0]

    marimo.md(
        f"""
### Forecast Summary
- Latest observed value: **{latest_actual['y']:.2f}** on **{latest_actual['ds']}**
- Next forecast value: **{first_fcst['yhat']:.2f}** on **{first_fcst['ds']}**
- 95% interval: **[{first_fcst['lo95']:.2f}, {first_fcst['hi95']:.2f}]**
"""
    )
  @app.cell
def _(marimo, result):
    if not result.ok:
        return

    forecast_table = (
        result.forecast
        .sort("ds")
        .with_columns([
            # optional: round numeric columns for readability
        ])
        .to_pandas()
    )

    marimo.vstack([
        marimo.md("### Forecast Table"),
        marimo.ui.table(forecast_table),
    ])
