import altair as alt
import marimo
import polars as pl

from src.forecast import available_filters, run_forecast

app = marimo.App(width="full")


@app.cell
def _():
    marimo.md(
        """
        # Olist Interactive Forecasting App
        Explore historical Olist marketplace performance and compare forward-looking forecasts.
        """
    )
    return


@app.cell
def _():
    metric_options = {
        "Monthly Revenue (BRL)": "monthly_revenue",
        "Order Volume": "order_volume",
        "Average Delivery Days": "delivery_days",
    }
    model_options = ["AutoARIMA", "SeasonalNaive", "AutoETS"]
    categories, states = available_filters()

    metric = marimo.ui.dropdown(options=metric_options, value="monthly_revenue", label="Metric")
    model = marimo.ui.dropdown(options=model_options, value="AutoARIMA", label="Forecast Model")
    horizon = marimo.ui.slider(start=3, stop=24, step=1, value=6, label="Forecast Horizon (months)")
    category = marimo.ui.dropdown(options=categories, value="All", label="Product Category Filter")
    state = marimo.ui.dropdown(options=states, value="All", label="Seller State Filter")

    marimo.hstack([metric, model, horizon, category, state], widths=[1, 1, 1, 2, 1])
    return metric, model, horizon, category, state


@app.cell
def _(category, horizon, metric, model, state):
    result = run_forecast(
        metric=metric.value,
        model_name=model.value,
        horizon=horizon.value,
        category=category.value,
        seller_state=state.value,
    )
    return result


@app.cell
def _(marimo, result):
    if not result.ok:
        marimo.callout(
            kind="warn",
            value=f"Cannot generate forecast: {result.message}",
        )
    return


@app.cell
def _(alt, pl, result):
    if not result.ok:
        return

    history = result.history.rename({"y": "actual"})
    forecast = result.forecast

    history_pd = history.to_pandas()
    forecast_pd = forecast.to_pandas()

    base = alt.Chart(history_pd).encode(x=alt.X("ds:T", title="Month"))
    actual_line = base.mark_line(color="#1f77b4", strokeWidth=2).encode(
        y=alt.Y("actual:Q", title="Metric Value"),
        tooltip=["ds:T", alt.Tooltip("actual:Q", format=",.2f")],
    )

    forecast_line = (
        alt.Chart(forecast_pd)
        .mark_line(color="#d62728", strokeDash=[6, 4], strokeWidth=2)
        .encode(
            x="ds:T",
            y="yhat:Q",
            tooltip=["ds:T", alt.Tooltip("yhat:Q", format=",.2f")],
        )
    )

    ci_band = (
        alt.Chart(forecast_pd)
        .mark_area(color="#ff9896", opacity=0.25)
        .encode(x="ds:T", y="lo95:Q", y2="hi95:Q")
    )

    forecast_vs_actual = (ci_band + actual_line + forecast_line).properties(
        title="Historical Actuals vs Forecast with 95% Confidence Interval",
        height=350,
    )

    return forecast_vs_actual, history, history_pd


@app.cell
def _(alt, history_pd, result):
    if not result.ok:
        return

    recent = history_pd.sort_values("ds").tail(12)
    recent_chart = (
        alt.Chart(recent)
        .mark_bar(color="#2ca02c")
        .encode(
            x=alt.X("ds:T", title="Recent Months"),
            y=alt.Y("actual:Q", title="Observed Value"),
            tooltip=["ds:T", alt.Tooltip("actual:Q", format=",.2f")],
        )
        .properties(title="Last 12 Months of Actual Observations", height=220)
    )
    return recent_chart


@app.cell
def _(alt, pl, result):
    if not result.ok:
        return

    history = result.history.rename({"y": "actual"})
    with_trend = history.with_columns(
        pl.col("actual").pct_change().mul(100).alias("pct_change")
    ).drop_nulls("pct_change")

    trend_chart = (
        alt.Chart(with_trend.to_pandas())
        .mark_line(point=True, color="#9467bd")
        .encode(
            x=alt.X("ds:T", title="Month"),
            y=alt.Y("pct_change:Q", title="Month-over-Month Change (%)"),
            tooltip=["ds:T", alt.Tooltip("pct_change:Q", format=".2f")],
        )
        .properties(title="Month-over-Month Percent Change", height=220)
    )
    return trend_chart


@app.cell
def _(forecast_vs_actual, marimo, recent_chart, result, trend_chart):
    if not result.ok:
        return

    marimo.vstack(
        [
            marimo.md("### Forecast Output"),
            marimo.ui.altair_chart(forecast_vs_actual),
            marimo.hstack(
                [marimo.ui.altair_chart(recent_chart), marimo.ui.altair_chart(trend_chart)]
            ),
        ]
    )
    return


if __name__ == "__main__":
    app.run()
